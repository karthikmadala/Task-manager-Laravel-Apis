APP_NAME="CryptoPortfolio"
APP_ENV=local
APP_KEY=base64:uW5iqUXmktf5UkYEdzlzUlrALsoZw6y9IzENilEfQO4=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ─── Database (MySQL) ────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=crypto_portfolio
DB_USERNAME=root
DB_PASSWORD=

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_STORE=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ─── Queue & Cache (Redis) ────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Sanctum ─────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080
SANCTUM_EXPIRATION=1440

# ─── Blockchain Node Service (internal) ──────────────────────────────────────
BLOCKCHAIN_SERVICE_URL=http://localhost:3000
BLOCKCHAIN_SERVICE_SECRET=change_me_to_a_random_secret_32ch

# ─── Ethereum / EVM RPC (fallback read-only) ─────────────────────────────────
