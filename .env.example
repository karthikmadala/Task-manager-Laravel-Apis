APP_NAME="CryptoPortfolio"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ─── Database (MySQL) ────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=crypto_portfolio
DB_USERNAME=crypto_user
DB_PASSWORD=crypto_password

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_STORE=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ─── Queue & Cache (Redis) ────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Sanctum ─────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080
SANCTUM_EXPIRATION=60

# ─── Blockchain Node Service (internal) ──────────────────────────────────────
BLOCKCHAIN_SERVICE_URL=http://localhost:3000
BLOCKCHAIN_SERVICE_SECRET=change_me_to_a_random_secret_32chars

# ─── Ethereum / EVM RPC (fallback read-only) ─────────────────────────────────
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
BNB_RPC_URL=https://bsc-dataseed1.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com

# Testnet RPC (used when APP_ENV=local)
ETH_RPC_URL_TESTNET=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
BNB_RPC_URL_TESTNET=https://data-seed-prebsc-1-s1.binance.org:8545
POLYGON_RPC_URL_TESTNET=https://polygon-amoy.drpc.org

# ─── Alchemy (on-chain data) ─────────────────────────────────────────────────
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_ETH_URL=https://eth-mainnet.g.alchemy.com/v2
ALCHEMY_POLYGON_URL=https://polygon-mainnet.g.alchemy.com/v2

# Testnet Alchemy (used when APP_ENV=local)
ALCHEMY_ETH_URL_TESTNET=https://eth-sepolia.g.alchemy.com/v2
ALCHEMY_POLYGON_URL_TESTNET=https://polygon-amoy.g.alchemy.com/v2

# ─── CoinGecko (price data) ──────────────────────────────────────────────────
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# ─── Block Explorer APIs (Etherscan-compatible) ──────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key
ETHERSCAN_API_URL=https://api.etherscan.io/api
ETHERSCAN_API_URL_TESTNET=https://api-sepolia.etherscan.io/api

BSCSCAN_API_KEY=your_bscscan_api_key
BSCSCAN_API_URL=https://api.bscscan.com/api
BSCSCAN_API_URL_TESTNET=https://api-testnet.bscscan.com/api

POLYGONSCAN_API_KEY=your_polygonscan_api_key
POLYGONSCAN_API_URL=https://api.polygonscan.com/api
POLYGONSCAN_API_URL_TESTNET=https://api-amoy.polygonscan.com/api

# ─── Bitcoin (read-only via BlockCypher) ─────────────────────────────────────
BLOCKCYPHER_TOKEN=
BLOCKCYPHER_BASE_URL=https://api.blockcypher.com/v1

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@cryptoportfolio.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
